# Configuração do Banco de Dados
# Opções: sqlite, mysql, postgres, mariadb
DB_DIALECT=sqlite

# Caminho do arquivo SQLite (ignorado se usar outro banco)
DB_STORAGE=database.sqlite

# Configurações para MySQL/PostgreSQL/MariaDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gtonline
DB_USER=root
DB_PASSWORD=password

# Configuração JWT
# Mude isso em produção! Use algo complexo
JWT_SECRET=sua_chave_super_secreta_aqui_mude_em_producao

# Tempo de expiração do token
# Formato: 7d, 24h, 3600s, etc
JWT_EXPIRES_IN=7d

# Configuração do Servidor
PORT=3000

# Ambiente
# Opções: development, production, test
NODE_ENV=development

# Logs (opcional)
# Opções: true, false
LOG_ENABLED=true
